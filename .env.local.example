# Public Builder.io API key — safe to commit/expose to the browser.
NEXT_PUBLIC_BUILDER_API_KEY=6728a5ea20e84fb486556b6399dea5b3

# Optional: secret used to verify Builder webhook -> /api/revalidate
BUILDER_WEBHOOK_SECRET=

# Optional: where /api/callback forwards new leads (Zapier, Make, etc.)
# Can also be set per-environment in Builder via the "Settings" model.
LEAD_WEBHOOK_URL=

# Existing Formspree endpoint (already used by the contact form)
NEXT_PUBLIC_FORMSPREE_ENDPOINT=
