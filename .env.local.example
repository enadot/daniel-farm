# Public Builder.io API key — safe to commit/expose to the browser.
NEXT_PUBLIC_BUILDER_API_KEY=6728a5ea20e84fb486556b6399dea5b3

# Optional: secret used to verify Builder webhook -> /api/revalidate
BUILDER_WEBHOOK_SECRET=

# Optional: where /api/callback forwards new leads (Zapier, Make, etc.)
# Can also be set inside our own admin panel at /admin
LEAD_WEBHOOK_URL=

# Existing Formspree endpoint (already used by the contact form)
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# Optional: Google Tag Manager container ID, format GTM-XXXXXXX.
# When set, this env var overrides whatever is configured in /admin.
NEXT_PUBLIC_GTM_ID=

# --- Admin panel at /admin -----------------------------------------
# Set a password to unlock the admin panel. If unset, /admin is locked
# to everyone (the panel still renders a "no password configured" message).
ADMIN_PASSWORD=

# A random string used to sign the admin cookie. Keep secret.
# Generate one with: openssl rand -hex 32
ADMIN_SECRET=

# --- Lead + settings persistence (Vercel KV / Upstash) -------------
# Enable in Vercel: Storage tab -> Create Database -> KV -> Connect.
# Vercel auto-populates these. Without them the admin panel still
# works in-memory (resets on deploy) — fine for testing, not for prod.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

